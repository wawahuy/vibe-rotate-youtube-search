{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 30
      }
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apps/api/src/vercel.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
