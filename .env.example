# ==============================================
# App
# ==============================================
NODE_ENV=development
PORT=3000

# ==============================================
# MongoDB
# ==============================================
MONGODB_URI=mongodb://localhost:27017/youtube-rotate-api

# ==============================================
# JWT
# ==============================================
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=24h

# ==============================================
# Admin Credentials
# ==============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ==============================================
# Encryption (for storing provider API keys)
# Must be exactly 32 characters
# ==============================================
ENCRYPTION_KEY=change-this-32-char-encryption!!

# ==============================================
# Optional: Default quota limit for provider keys
# ==============================================
DEFAULT_QUOTA_LIMIT=10000
