# Environment Variables

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/youtube-rotate

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Encryption (AES-256, must be 32 chars)
ENCRYPTION_SECRET=your-32-char-encryption-secret!!

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# YouTube Data API keys (comma separated)
YOUTUBE_API_KEYS=AIzaXXXXX,AIzaYYYYY

# SerpAPI keys (comma separated)
SERPAPI_KEYS=serpapi_key_1,serpapi_key_2

# yt-dlp fallback remote service (optional)
YTDLP_REMOTE_URL=https://your-yt-dlp-service.com

# Next.js API base
NEXT_PUBLIC_API_URL=http://localhost:3001
